# ============================================================
# Docker Compose 环境变量模板
# 复制此文件并填入强密码:
#   cp .env.compose.example .env.compose
# 用法:
#   docker compose --env-file .env.compose up -d
# ============================================================

# PostgreSQL 密码（必填）
POSTGRES_PASSWORD=<在此填入强密码>

# Valkey 密码（必填）
VALKEY_PASSWORD=<在此填入强密码>

# JWT 密钥（必填，至少 32 个字符，建议用 openssl rand -hex 32 生成）
APP__JWT__SECRET=<在此填入强随机字符串>
