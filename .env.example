# 运行环境：development | production | test
# 必须显式设置，不提供默认 fallback
APP_ENV=development

# 可选：覆盖配置文件目录（默认 ./config）
# CONFIG_DIR=/app/config

# 服务端
APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=3000

# 数据库
APP__DATABASE__URL=postgres://user:password@127.0.0.1:5432/api_platform
APP__DATABASE__MAX_CONNECTIONS=10
APP__DATABASE__MIN_CONNECTIONS=1
APP__DATABASE__ACQUIRE_TIMEOUT_SECONDS=30
APP__DATABASE__IDLE_TIMEOUT_MINUTES=30

# Valkey 缓存
APP__VALKEY__URL=redis://127.0.0.1:6379
APP__VALKEY__POOL_SIZE=8
APP__VALKEY__CONNECT_TIMEOUT_SECONDS=5
APP__VALKEY__INTERNAL_COMMAND_TIMEOUT_SECONDS=10

# JWT 认证
# 生产环境必须使用强随机值，至少 32 字符
APP__JWT__SECRET=change-me-to-a-strong-random-secret-32
APP__JWT__EXPIRY_HOURS=24

# 日志
APP__LOGGING__LEVEL=info
APP__LOGGING__FORMAT=json
